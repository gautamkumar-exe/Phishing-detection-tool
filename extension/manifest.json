{
  "manifest_version": 3,
  "name": "Phishing Detector",
  "version": "1.0",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": [
    "https://phishing-detection-tool-728u.onrender.com/*",
    "http://*/*", 
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}