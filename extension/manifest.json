{
  "manifest_version": 3,
  "name": "Phishing Detector",
  "version": "1.0",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": ["http://127.0.0.1:5002/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}